<Application x:Class="WpfNotesSystemProg.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfNotesSystemProg.Views"
             StartupUri="MainView.xaml"
             xmlns:views="clr-namespace:WpfNotesSystemProg.Views"
             xmlns:viewModels="clr-namespace:WpfNotesSystemProg.ViewModels">
    <Application.Resources>
      <DataTemplate DataType="{x:Type viewModels:FolderViewModel}">
         <views:FolderView/>
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:TextViewModel}">
         <views:TextView/>
      </DataTemplate>
   </Application.Resources>
</Application>
