<Application x:Class="SwitchingViewsMVVM.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SwitchingViewsMVVM"
             xmlns:views="clr-namespace:SwitchingViewsMVVM.Views"
             xmlns:viewmodels="clr-namespace:SwitchingViewsMVVM.ViewModels"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        

      <ResourceDictionary>
         <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary 
            Source="Styles/TempBorderStyle.xaml" />
            <ResourceDictionary>
               <DataTemplate DataType="{x:Type viewmodels:FolderViewModel}">
                  <views:FolderView/>
               </DataTemplate>
               <DataTemplate DataType="{x:Type viewmodels:TextViewModel}">
                  <views:TextView/>
               </DataTemplate>
            </ResourceDictionary>
         </ResourceDictionary.MergedDictionaries>
      </ResourceDictionary>
   </Application.Resources>
</Application>
